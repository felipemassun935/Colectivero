{
  "expo": {
    "name": "Colectivero",
    "slug": "colectivero",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "colectivero",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0D0D0D"
    },
    "ios": { "supportsTablet": false },
    "android": { "adaptiveIcon": { "backgroundColor": "#0D0D0D" } },
